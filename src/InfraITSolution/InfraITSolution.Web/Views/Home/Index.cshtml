@{
    ViewData["Title"] = "Welcome to InfraIT Solution";
}

<section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="hero-content">

        <img src="@(Url.Content("~/images/logo-hero.webp"))" alt="InfraIT logo" style="max-width:320px; width:100%; height:auto; margin-bottom:1rem;" />

        <h1 class="display-4 fw-bold">InfraIT Solution</h1>

        <p class="lead">
            Efficient IT infrastructure and incident management system.
        </p>
        <div class="mt-4">
            @if (!User.Identity.IsAuthenticated)
            {
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg me-2">Create Account</a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-light btn-lg">Login</a>
            }
            else
            {
                <a asp-action="Dashboard" class="btn btn-light btn-lg">Go to Dashboard</a>
            }
        </div>
    </div>
</section>

<div class="container py-5">
    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="feature-icon text-primary">
                <i class="bi bi-ticket-perforated" style="font-size: 2.5rem;"></i>
            </div>
            <h4>Incident Management</h4>
            <p class="text-muted">Track and resolve technical issues efficiently.</p>
        </div>
        <div class="col-md-4 mb-4">
            <div class="feature-icon text-primary">
                <i class="bi bi-hdd" style="font-size: 2.5rem;"></i>
            </div>
            <h4>Asset Tracking</h4>
            <p class="text-muted">Keep inventory of hardware and software.</p>
        </div>
        <div class="col-md-4 mb-4">
            <div class="feature-icon text-primary">
                <i class="bi bi-bar-chart" style="font-size: 2.5rem;"></i>
            </div>
            <h4>Performance Reports</h4>
            <p class="text-muted">Monitor SLAs and team productivity.</p>
        </div>
    </div>
</div>